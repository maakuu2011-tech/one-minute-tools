---
import Layout from "../../components/Layout.astro";
import MascotGuide from "../../components/MascotGuide.astro";
import ToolCard from "../../components/ToolCard.astro";
import tools from "../../data/tools.json";
import usePages from "../../data/usePages.json";

export function getStaticPaths() {
  return usePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const siteUrl = "https://one-minute-tools.pages.dev";
const pageUrl = new URL(`/use/${page.slug}/`, siteUrl).toString();
const seoDescription = `${page.title}。${page.description}そのまま使える例文、よくある質問、関連する無料ツールをまとめています。`;
const relatedTools = page.toolIds
  .map((id) => tools.find((tool) => tool.id === id))
  .filter(Boolean);
const primaryTool = relatedTools[0];

const relatedUsePages = usePages
  .filter((item) => item.slug !== page.slug)
  .filter((item) =>
    item.label === page.label ||
    item.toolIds.some((id) => page.toolIds.includes(id)) ||
    item.searchIntents.some((intent) =>
      page.searchIntents.some((current) => current.split(" ")[0] && intent.includes(current.split(" ")[0]))
    )
  )
  .slice(0, 3);

const fallbackUsePages = usePages.filter((item) => item.slug !== page.slug).slice(0, 3);
const nextUsePages = relatedUsePages.length ? relatedUsePages : fallbackUsePages;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: page.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "1分ツール",
      item: siteUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "用途から探す",
      item: new URL("/use/", siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: page.title,
      item: pageUrl,
    },
  ],
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: page.title,
  description: seoDescription,
  url: pageUrl,
  inLanguage: "ja",
  isPartOf: {
    "@type": "WebSite",
    name: "1分ツール",
    url: siteUrl,
  },
};
---

<Layout
  title={`${page.title}｜例文と無料ツール`}
  description={seoDescription}
  structuredData={[webPageSchema, breadcrumbSchema, faqSchema]}
>
  <main class="page">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href="/">1分ツール</a>
        <span>/</span>
        <a href="/use/">用途から探す</a>
        <span>/</span>
        <span>{page.label}</span>
      </nav>

      <section class="hero use-hero">
        <span class="hero__label">{page.label}</span>
        <h1>{page.headline}</h1>
        <p>{page.lead}</p>
      </section>

      <MascotGuide
        title="このページの使い方"
        message="例文をそのまま使ってもいいし、近いツールを開いて自分の状況に合わせて作り直してもOKです。"
      />

      <section class="seo-content use-content">
        <h2>よく検索される困りごと</h2>
        <div class="intent-list">
          {page.searchIntents.map((item) => <span>{item}</span>)}
        </div>

        {
          page.subjectLines?.length > 0 && (
            <>
              <h2>使いやすい件名例</h2>
              <p class="section__note">氏名、日付、会社名、対象名を自分の内容に置き換えてください。</p>
              <div class="subject-line-list">
                {page.subjectLines.map((subject) => (
                  <div class="subject-line-item">
                    <span>{subject}</span>
                    <button class="example-copy-button" type="button" data-copy-text={subject}>コピー</button>
                  </div>
                ))}
              </div>
            </>
          )
        }

        <h2>そのまま使える例文</h2>
        <div class="example-list">
          {page.examples.map((example) => (
            <article class="example-card">
              <h3>{example.situation}</h3>
              <p>{example.text}</p>
              <button class="example-copy-button" type="button" data-copy-text={example.text}>コピー</button>
            </article>
          ))}
        </div>

        <h2>次にやること</h2>
        <div class="next-action-grid">
          {
            primaryTool && (
              <a class="next-action-card" href={primaryTool.href}>
                <span>作る</span>
                <strong>{primaryTool.title}を開く</strong>
                <p>近い文面を入力して、自分の状況に合う文章へ整えます。</p>
              </a>
            )
          }
          <a class="next-action-card" href="/use/">
            <span>探す</span>
            <strong>別の困りごとを見る</strong>
            <p>似た場面の例文から、もっと近い言い方を探せます。</p>
          </a>
          <a class="next-action-card" href="/tools/">
            <span>一覧</span>
            <strong>文章ツール一覧へ</strong>
            <p>チャット、メール、断り方、催促などから直接選べます。</p>
          </a>
        </div>

        <h2>この場面で使えるツール</h2>
        <div class="tool-grid tool-grid--compact">
          {relatedTools.map((tool) => <ToolCard tool={tool} />)}
        </div>

        <h2>近い困りごと</h2>
        <div class="use-list use-list--related">
          {nextUsePages.map((item) => (
            <a class="use-card use-card--mini" href={`/use/${item.slug}/`}>
              <span>{item.label}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </a>
          ))}
        </div>

        {
          page.checklist?.length > 0 && (
            <>
              <h2>送信前のチェック</h2>
              <div class="send-checklist">
                {page.checklist.map((item) => (
                  <label>
                    <input type="checkbox" />
                    <span>{item}</span>
                  </label>
                ))}
              </div>
            </>
          )
        }

        <h2>よくある質問</h2>
        <div class="faq-list">
          {page.faq.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
  </main>
  <div id="toast" class="toast"></div>
  <script is:inline src="/scripts/use-example-copy.js"></script>
</Layout>
