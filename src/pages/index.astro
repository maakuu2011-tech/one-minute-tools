---
import Layout from "../components/Layout.astro";
import IconBadge from "../components/IconBadge.astro";
import tools from "../data/tools.json";
import usePages from "../data/usePages.json";
import minuteContents from "../data/minuteContents.json";
import games from "../data/games.json";

const popularToolItems = [
  { id: "chat-reply", reason: "LINE・Slackの返事で一番使いやすい入口", icon: "chat" },
  { id: "keigo-mail", reason: "仕事メールの返信を短く整えたいときに便利", icon: "mail" },
  { id: "decline-reply", reason: "断りづらい誘いや依頼をやわらかくできる", icon: "decline" },
  { id: "soft-rewrite", reason: "冷たく見える文章を送る前に直せる", icon: "rewrite" },
]
  .map((item) => ({ ...item, tool: tools.find((tool) => tool.id === item.id) }))
  .filter((item) => item.tool);
const categoryLinks = [
  { label: "チャット返信", href: "/tools/chat-reply/", note: "LINE・Slackの返事", icon: "chat" },
  { label: "断り方", href: "/tools/decline-reply/", note: "角が立たない断り文", icon: "decline" },
  { label: "催促", href: "/tools/follow-up-message/", note: "返信・確認のお願い", icon: "remind" },
  { label: "言い換え", href: "/tools/soft-rewrite/", note: "やわらかい表現へ", icon: "rewrite" },
];
const searchSuggestions = [
  { label: "LINE返信", href: "/use/line-reply-examples/" },
  { label: "確認依頼", href: "/use/confirmation-request-examples/" },
  { label: "休み連絡", href: "/use/absence-message-examples/" },
  { label: "日程調整", href: "/use/schedule-adjust-examples/" },
  { label: "断り方", href: "/use/decline-without-offense/" },
  { label: "謝罪メール", href: "/tools/apology-mail/" },
  { label: "お礼メール", href: "/tools/thanks-mail/" },
];
const priorityUseSlugs = [
  "confirmation-request-examples",
  "absence-message-examples",
  "paid-leave-request-examples",
  "schedule-adjust-examples",
  "payment-reminder-examples",
  "thanks-mail-examples",
  "customer-support-reply-examples",
  "decline-without-offense",
];
const priorityUsePages = priorityUseSlugs
  .map((slug) => usePages.find((page) => page.slug === slug))
  .filter(Boolean);
const useIconMap = {
  確認依頼: "search",
  休み連絡: "chat",
  有給申請: "example",
  日程調整: "minute",
  支払い催促: "remind",
  お礼: "mail",
  問い合わせ返信: "chat",
  断り方: "decline",
};
const quickEntrances = [
  {
    icon: "chat",
    label: "返信する",
    title: "チャットの返事を短く整える",
    description: "相手の文と伝えたい内容を入れて、LINEやSlackで使える返事を作れます。",
    href: "/tools/chat-reply/",
    action: "返信文を作る",
  },
  {
    icon: "mail",
    label: "メールを作る",
    title: "仕事メールを丁寧な文章にする",
    description: "敬語、謝罪、催促、お礼など、仕事で使うメールを用件に合わせて作れます。",
    href: "/tools/keigo-mail/",
    action: "メール文を作る",
  },
  {
    icon: "example",
    label: "場面から探す",
    title: "今の状況に近い例文を見つける",
    description: `${usePages.length}件の仕事・連絡場面から、コピペできる例文と作成ツールを探せます。`,
    href: "/use/",
    action: "場面別の例文を見る",
  },
];

const minuteIcons = {
  生活: "minute",
  仕事: "tool",
  文章: "rewrite",
  集中: "rank",
  メモ: "example",
};
---

<Layout
  title="1分ツール｜仕事の返信・メール・言い回しを無料で作成"
  description="仕事のチャット返信、敬語メール、断り文、催促文、謝罪文を1分で作成。登録不要・無料で、入力内容はブラウザ内だけで処理されます。"
>
  <main>
    <section class="hero">
      <div class="container hero__grid">
        <div>
          <span class="hero__label">登録不要・無料の文章作成ツール</span>
          <h1>仕事の返信・メールを、1分で使える文章に。</h1>
          <p>
            チャット返信、敬語メール、断り文、催促文、謝罪文。
            相手と用件に合わせて、コピペして使える自然な文章を作れます。
          </p>
          <form class="home-search" action="/tools/" method="get" role="search">
            <label for="homeToolSearch">使いたいツールを探す</label>
            <div>
              <input id="homeToolSearch" name="q" type="search" placeholder="例：LINE、断り方、催促、敬語" />
              <button class="button primary" type="submit">探す</button>
            </div>
          </form>
          <div class="home-suggestion-row" aria-label="よく使う入口">
            {searchSuggestions.map((item) => <a href={item.href}>{item.label}</a>)}
          </div>
        </div>
        <div class="mascot-card" aria-label="1分ツールのマスコット">
          <img src="/images/mascot-girl.png" alt="1分ツールのマスコットキャラクター" />
          <div class="mascot-card__bubble">今の用件に合う文章を一緒に作ります。</div>
        </div>
      </div>
    </section>

    <section class="section section--tight" aria-label="サービスの特徴">
      <div class="container trust-strip">
        <div><strong>登録不要</strong><span>すぐ使えます</span></div>
        <div><strong>無料</strong><span>料金はかかりません</span></div>
        <div><strong>ブラウザ内処理</strong><span>入力文を保存しません</span></div>
        <div><strong>編集して送れる</strong><span>結果をその場で調整できます</span></div>
      </div>
    </section>

    <section class="section section--tight">
      <div class="container">
        <div class="quick-entrance" aria-label="目的別の入口">
          {quickEntrances.map((item) => (
            <a class="quick-entrance__card" href={item.href}>
              <div class="card-icon-row">
                <IconBadge name={item.icon} />
                <span>{item.label}</span>
              </div>
              <h2>{item.title}</h2>
              <p>{item.description}</p>
              <strong>{item.action}</strong>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--tight">
      <div class="container">
        <div class="category-strip">
          {categoryLinks.map((item) => (
            <a class="category-link" href={item.href}>
              <IconBadge name={item.icon} />
              <span>{item.label}</span>
              <small>{item.note}</small>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--tight">
      <div class="container">
        <div class="section__head">
          <div>
            <h2>よく使う用途から探す</h2>
            <p class="section__note">検索されやすい文章の悩みを、例文と作成ツールへ直接つなげています。</p>
          </div>
          <a class="button secondary" href="/use/">用途一覧へ</a>
        </div>
        <div class="home-use-grid">
          {priorityUsePages.map((page) => (
            <a class="home-use-card" href={`/use/${page.slug}/`}>
              <div class="card-icon-row">
                <IconBadge name={useIconMap[page.label] || "example"} />
                <span>{page.label}</span>
              </div>
              <h3>{page.title}</h3>
              <p>{page.description}</p>
              <small>{page.searchIntents?.[0] || "例文を探す"}</small>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section__head">
          <div>
            <h2>人気ツール</h2>
            <p class="section__note">迷ったらまずここから。使う場面が多いものを順位つきで並べています。</p>
          </div>
          <a class="button secondary" href="/tools/">すべて見る</a>
        </div>
        <div class="popular-tool-list">
          {popularToolItems.map((item, index) => (
            <a class="popular-tool" href={item.tool.href}>
              <span class="popular-tool__rank">{index + 1}</span>
              <div>
                <div class="tool-card__top">
                  <IconBadge name={item.icon} />
                  <span class="tool-card__category">{item.tool.category}</span>
                </div>
                <h3>{item.tool.title}</h3>
                <p>{item.reason}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--brand">
      <div class="container brand-summary">
        <div>
          <span class="hero__label">安心して使うために</span>
          <h2>入力した文章は、外部へ送信・保存しません。</h2>
        </div>
        <p>
          文章の作成処理はこのブラウザ内で行います。作った文はそのまま送らず、宛名、日付、事実関係、相手との関係に合っているかを確認してからお使いください。
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section__head">
          <div>
            <h2>1分でできること</h2>
            <p class="section__note">文章作成以外にも、仕事や生活で試せる小さな行動を増やしています。</p>
          </div>
          <a class="button secondary" href="/one-minute/">すべて見る</a>
        </div>
        <div class="minute-grid minute-grid--home">
          {minuteContents.slice(0, 3).map((item) => (
            <a class="minute-card" href={`/one-minute/${item.slug}/`}>
              <div class="card-icon-row">
                <IconBadge name={minuteIcons[item.category] || "minute"} />
                <span>{item.category}</span>
              </div>
              <strong>{item.time}</strong>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--compact">
      <div class="container secondary-content-banner">
        <img src="/images/mascot-game.png" alt="ゲームを案内するマスコットキャラクター" />
        <div>
          <span>休憩用コンテンツ</span>
          <h2>文章作成の合間に、1分だけ遊ぶ。</h2>
          <p>{games.length}本のミニゲームと端末内ランキングも用意しています。</p>
        </div>
        <div class="actions actions--inline">
          <a class="button secondary" href="/games/">ゲーム一覧</a>
          <a class="button secondary" href="/games/ranking/">ランキング</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
