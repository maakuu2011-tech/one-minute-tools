---
import Layout from "../components/Layout.astro";
import ToolCard from "../components/ToolCard.astro";
import tools from "../data/tools.json";
import usePages from "../data/usePages.json";
import minuteContents from "../data/minuteContents.json";

const publishedTools = tools.filter((tool) => tool.status === "公開中").slice(0, 6);
const categoryLinks = [
  { label: "チャット返信", href: "/tools/chat-reply/", note: "LINE・Slackの返事" },
  { label: "断り方", href: "/tools/decline-reply/", note: "角が立たない断り文" },
  { label: "催促", href: "/tools/follow-up-message/", note: "返信・確認のお願い" },
  { label: "言い換え", href: "/tools/soft-rewrite/", note: "やわらかい表現へ" },
];
---

<Layout
  title="1分ツール｜チャット返信や文章作成をすぐ整える"
  description="チャット返信、敬語メール、謝罪文、お礼文など、仕事や生活の小さな文章作成をすぐ片づける無料ツール集です。"
>
  <main>
    <section class="hero">
      <div class="container hero__grid">
        <div>
          <span class="hero__label">無料で使える小ツール集</span>
          <h1>返し方に困る文章を、1分で整える。</h1>
          <p>
            チャット返信、メール文、謝罪文、お礼文。毎回考えるのが面倒な文章を、
            すぐ使える小さなツールとしてまとめています。
          </p>
          <form class="home-search" action="/tools/" method="get" role="search">
            <label for="homeToolSearch">使いたいツールを探す</label>
            <div>
              <input id="homeToolSearch" name="q" type="search" placeholder="例：LINE、断り方、催促、敬語" />
              <button class="button primary" type="submit">探す</button>
            </div>
          </form>
        </div>
        <div class="mascot-card" aria-label="1分ツールのマスコット">
          <img src="/images/mascot-girl.png" alt="1分ツールのマスコットキャラクター" />
          <div class="mascot-card__bubble">文章づくり、手伝います。</div>
        </div>
      </div>
    </section>

    <section class="section section--tight">
      <div class="container">
        <div class="category-strip">
          {categoryLinks.map((item) => (
            <a class="category-link" href={item.href}>
              <span>{item.label}</span>
              <small>{item.note}</small>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section__head">
          <div>
            <h2>ツール</h2>
            <p class="section__note">チャットやメールなど、返し方に困る文章から増やしています。</p>
          </div>
          <a class="button secondary" href="/tools/">すべて見る</a>
        </div>
        <div class="tool-grid">
          {publishedTools.map((tool) => <ToolCard tool={tool} />)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section__head">
          <div>
            <h2>困った場面から探す</h2>
            <p class="section__note">検索されやすい悩みごと別に、例文と使えるツールをまとめています。</p>
          </div>
          <a class="button secondary" href="/use/">用途一覧へ</a>
        </div>
        <div class="use-list use-list--home">
          {usePages.slice(0, 3).map((page) => (
            <a class="use-card" href={`/use/${page.slug}/`}>
              <span>{page.label}</span>
              <h3>{page.title}</h3>
              <p>{page.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section__head">
          <div>
            <h2>1分でできること</h2>
            <p class="section__note">文章作成以外にも、仕事や生活で試せる小さな行動を増やしています。</p>
          </div>
          <a class="button secondary" href="/one-minute/">すべて見る</a>
        </div>
        <div class="minute-grid minute-grid--home">
          {minuteContents.slice(0, 4).map((item) => (
            <a class="minute-card" href={`/one-minute/${item.slug}/`}>
              <span>{item.category}</span>
              <strong>{item.time}</strong>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
