---
import IconBadge from "../../components/IconBadge.astro";
import Layout from "../../components/Layout.astro";
import MascotGuide from "../../components/MascotGuide.astro";
import games from "../../data/games.json";
import { SITE_URL } from "../../../site.config.mjs";

const gameIcons = {
  反射神経: "game",
  記憶: "example",
  パズル: "tool",
  計算: "minute",
  判断力: "search",
  集中力: "rank",
  戦略: "game",
  迷路: "maze",
  言葉: "word",
};

const featuredGames = ["janken-reaction", "number-order", "sea-battle"]
  .map((slug) => games.find((game) => game.slug === slug))
  .filter(Boolean);
const categories = Array.from(new Set(games.map((game) => game.category)));
const groupedGames = categories.map((category) => ({
  category,
  games: games.filter((game) => game.category === category),
}));

const gameListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "1分ゲーム",
  itemListElement: games.map((game, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(`/games/${game.slug}/`, SITE_URL).toString(),
    name: game.title,
    description: game.description,
  })),
};
---

<Layout
  title="1分ゲーム｜暇つぶしに遊べるミニゲーム"
  description="1分ゲームは、60秒で遊べる無料ミニゲーム集です。反射神経、記憶、マインスイーパー、計算、色合わせなどをブラウザですぐ遊べます。"
  structuredData={[gameListSchema]}
>
  <main class="page">
    <div class="container">
      <section class="hero game-hero">
        <span class="hero__label">1分ゲーム</span>
        <h1>暇つぶしに、1分だけ遊ぶ。</h1>
        <p>
          休憩中や待ち時間にすぐ遊べる、60秒で終わるミニゲームです。
          スコアが出るので、ちょっとだけもう一回ができます。
        </p>
        <div class="actions">
          <a class="button primary" href="/games/ranking/">ランキングを見る</a>
        </div>
      </section>

      <MascotGuide
        title="ゲーム案内"
        message={`${games.length}本の1分ゲームがあります。迷ったら、じゃんけん反射か数字順タップからどうぞ。`}
        variant="game"
      />

      <section class="game-summary" aria-label="1分ゲームの概要">
        <div>
          <span>ゲーム数</span>
          <strong>{games.length}</strong>
        </div>
        <div>
          <span>プレイ時間</span>
          <strong>60秒</strong>
        </div>
        <div>
          <span>記録</span>
          <strong>端末内</strong>
        </div>
      </section>

      <section class="section section--tight">
        <div class="section__head">
          <div>
            <h2>まず遊ぶなら</h2>
            <p class="section__note">ルールがすぐわかるものを先に置いています。</p>
          </div>
        </div>
        <div class="game-grid game-grid--featured">
          {featuredGames.map((game) => (
            <a class="game-card game-card--featured" href={`/games/${game.slug}/`}>
              <div class="card-icon-row">
                <IconBadge name={gameIcons[game.category] || "game"} />
                <span>{game.category}</span>
              </div>
              <strong>{game.time}</strong>
              <h2>{game.title}</h2>
              <p>{game.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="section section--tight" aria-label="1分ゲームカテゴリ">
        <div class="section__head">
          <div>
            <h2>カテゴリから探す</h2>
            <p class="section__note">気分に合わせて、反射・記憶・パズル・言葉などから選べます。</p>
          </div>
        </div>
        <div class="game-category-strip">
          {groupedGames.map((group) => (
            <a href={`#game-category-${group.category}`}>
              <IconBadge name={gameIcons[group.category] || "game"} />
              <span>{group.category}</span>
              <small>{group.games.length}本</small>
            </a>
          ))}
        </div>
      </section>

      <section class="game-category-list" aria-label="1分ゲーム一覧">
        {groupedGames.map((group) => (
          <section class="game-category-section" id={`game-category-${group.category}`}>
            <div class="section__head section__head--compact">
              <div>
                <h2>{group.category}</h2>
                <p class="section__note">{group.games.length}本のゲームがあります。</p>
              </div>
            </div>
            <div class="game-grid">
              {group.games.map((game) => (
                <a class="game-card" href={`/games/${game.slug}/`}>
                  <div class="card-icon-row">
                    <IconBadge name={gameIcons[game.category] || "game"} />
                    <span>{game.category}</span>
                  </div>
                  <strong>{game.time}</strong>
                  <h3>{game.title}</h3>
                  <p>{game.description}</p>
                </a>
              ))}
            </div>
          </section>
        ))}
      </section>
    </div>
  </main>
</Layout>
