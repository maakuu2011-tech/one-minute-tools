---
import Layout from "../../components/Layout.astro";
import games from "../../data/games.json";

const rankingSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "1分ゲームランキング",
  description: "1分ゲームのランキングを確認できるページです。端末内ランキングに加えて、Cloudflare D1設定後は全ユーザー共通ランキングにも対応します。",
  url: "https://one-minute-tools.pages.dev/games/ranking/",
};
---

<Layout
  title="1分ゲームランキング｜1分ツール"
  description="1分タップ反射ゲーム、1分マインスイーパー、1分計算ゲームなどのランキングを確認できます。端末内記録と全ユーザー共通ランキングに対応予定です。"
  structuredData={[rankingSchema]}
>
  <main class="page">
    <div class="container">
      <section class="hero game-hero">
        <span class="hero__label">ランキング</span>
        <h1>1分ゲームの記録を見る。</h1>
        <p>
          このブラウザに保存された記録を確認できます。Cloudflare D1をつなぐと、全ユーザー共通ランキングも表示できます。
        </p>
      </section>

      <section class="ranking-grid" aria-label="1分ゲームランキング一覧">
        {games.map((game) => (
          <article class="ranking-card">
            <div class="ranking-card__head">
              <span>{game.category}</span>
              <h2>{game.title}</h2>
              <a href={`/games/${game.slug}/`}>遊ぶ</a>
            </div>
            <div class="ranking-card__lists">
              <div>
                <h3>みんな</h3>
                <ol class="ranking-list" data-global-ranking-board={game.slug}></ol>
              </div>
              <div>
                <h3>この端末</h3>
                <ol class="ranking-list" data-ranking-board={game.slug}></ol>
              </div>
            </div>
          </article>
        ))}
      </section>
    </div>
  </main>
  <script type="application/json" id="games-data" set:html={JSON.stringify(games)}></script>
  <script src="/scripts/game-ranking.js" defer></script>
  <script src="/scripts/game-ranking-page.js" defer></script>
</Layout>
