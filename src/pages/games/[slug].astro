---
import IconBadge from "../../components/IconBadge.astro";
import Layout from "../../components/Layout.astro";
import MascotGuide from "../../components/MascotGuide.astro";
import games from "../../data/games.json";

export function getStaticPaths() {
  return games.map((game) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
const relatedGames = games.filter((item) => item.slug !== game.slug).slice(0, 3);
const seoDescription = `${game.title}は、${game.description}登録不要・無料でブラウザからすぐ遊べる1分ミニゲームです。`;
const gameIcons = {
  反射神経: "game",
  記憶: "example",
  パズル: "tool",
  計算: "minute",
  判断力: "search",
  集中力: "rank",
  戦略: "game",
};

const gameSchema = {
  "@context": "https://schema.org",
  "@type": "Game",
  name: game.title,
  description: game.description,
  url: new URL(`/games/${game.slug}/`, "https://one-minute-tools.pages.dev").toString(),
  playMode: "SinglePlayer",
};
---

<Layout title={`${game.title}｜無料で遊べる1分ゲーム`} description={seoDescription} structuredData={[gameSchema]}>
  <main class="page">
    <div class="container">
      <section class="hero game-hero">
        <span class="hero__label">{game.category}</span>
        <h1>{game.headline}</h1>
        <p>{game.lead}</p>
      </section>

      <MascotGuide
        title="遊び方"
        message="スタートを押すと60秒で始まります。終わったらスコアを見て、気が向いたらもう一回どうぞ。"
      />

      <section class="game-shell" data-game={game.slug}>
        <div class="game-stats" aria-label="ゲーム状況">
          <div>
            <span>残り</span>
            <strong id="gameTime">60</strong>
          </div>
          <div>
            <span>スコア</span>
            <strong id="gameScore">0</strong>
          </div>
          <div>
            <span>ベスト</span>
            <strong id="gameBest">0</strong>
          </div>
        </div>

        <div id="gameBoard" class="game-board" aria-live="polite">
          <div class="game-ready">
            <img src="/images/mascot-girl.png" alt="1分ツールのマスコットキャラクター" />
            <p>スタートを押して遊んでください。</p>
          </div>
        </div>

        <div class="actions game-actions">
          <button class="button primary" id="gameStart" type="button">スタート</button>
          <button class="button secondary" id="gameReset" type="button">リセット</button>
          <a class="button secondary" href="/games/ranking/">ランキング</a>
          <a class="button secondary" href="/games/">ゲーム一覧へ</a>
        </div>
      </section>

      <section class="ranking-panel" aria-labelledby="rankingTitle">
        <div class="section__head section__head--compact">
          <div>
            <h2 id="rankingTitle">ランキング</h2>
            <p class="section__note">この端末の記録と、準備できたら全ユーザー共通ランキングを表示します。</p>
          </div>
          <a class="button secondary" href="/games/ranking/">ランキング一覧へ</a>
        </div>
        <div class="ranking-columns">
          <div>
            <h3>みんなのランキング</h3>
            <ol class="ranking-list" id="globalRankingList"></ol>
          </div>
          <div>
            <h3>この端末のランキング</h3>
            <ol class="ranking-list" id="rankingList"></ol>
          </div>
        </div>
      </section>

      <section class="seo-content game-content">
        <h2>スコアを伸ばすコツ</h2>
        <ul class="tip-list">
          {game.tips.map((tip) => <li>{tip}</li>)}
        </ul>
      </section>

      <section class="section game-related" aria-label="ほかの1分ゲーム">
        <div class="section__head">
          <div>
            <h2>ほかの1分ゲーム</h2>
            <p class="section__note">もう少しだけ遊ぶなら、近いサイズのゲームもあります。</p>
          </div>
          <a class="button secondary" href="/games/">すべて見る</a>
        </div>
        <div class="game-grid game-grid--related">
          {relatedGames.map((item) => (
            <a class="game-card" href={`/games/${item.slug}/`}>
              <div class="card-icon-row">
                <IconBadge name={gameIcons[item.category] || "game"} />
                <span>{item.category}</span>
              </div>
              <strong>{item.time}</strong>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>
  <script type="application/json" id="game-meta" set:html={JSON.stringify({ slug: game.slug })}></script>
  <script src="/scripts/game-ranking.js" defer></script>
  <script src={game.script} defer></script>
</Layout>
