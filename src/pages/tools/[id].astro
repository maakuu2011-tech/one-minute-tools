---
import Layout from "../../components/Layout.astro";
import MascotGuide from "../../components/MascotGuide.astro";
import tools from "../../data/tools.json";

export function getStaticPaths() {
  const customToolIds = new Set([
    "chat-reply",
    "keigo-mail",
    "apology-mail",
    "thanks-mail",
    "decline-reply",
    "follow-up-message",
    "soft-rewrite",
    "line-reply",
    "keigo-converter",
    "late-reply-apology",
    "work-request-decline",
    "boss-reminder",
  ]);

  return tools
    .filter((tool) => !customToolIds.has(tool.id))
    .map((tool) => ({
      params: { id: tool.id },
      props: { tool },
    }));
}

const { tool } = Astro.props;
const seoDescription = `${tool.title}は、${tool.description}登録不要・無料でブラウザからすぐ使える文章作成ツールです。`;

const relatedTools = tools
  .filter((item) => item.id !== tool.id && item.category === tool.category)
  .slice(0, 3);
---

<Layout title={`${tool.title}｜無料の文章作成ツール`} description={seoDescription}>
  <main class="page">
    <div class="container">
      <section class="hero" style="padding-top: 10px;">
        <span class="hero__label">{tool.category}</span>
        <h1>{tool.title}</h1>
        <p>{tool.description}</p>
      </section>

      <MascotGuide
        title="このツールの使い方"
        message="まずは短めで作って、必要なら丁寧に切り替えてください。最後に自分の言葉を一言足すと自然です。"
      />

      <div class="tool-layout">
        <section class="panel">
          <h2>入力</h2>
          <div class="hint">内容を入れて、相手・雰囲気・長さを選ぶと、そのまま使いやすい文章に整えます。</div>

          <div class="field">
            <label for="incoming" id="incomingLabel">元の内容・相手から来た文章</label>
            <textarea id="incoming" placeholder="例：相手から来た文章、または伝えたい内容を入力してください"></textarea>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="purpose">目的</label>
              <select id="purpose">
                <option value="reply">返信する</option>
                <option value="decline">断る</option>
                <option value="request">お願いする</option>
                <option value="remind">催促する</option>
                <option value="thanks">お礼する</option>
                <option value="apology">謝る</option>
                <option value="report">報告する</option>
                <option value="rewrite">言い換える</option>
              </select>
            </div>

            <div class="field">
              <label for="relationship">相手</label>
              <select id="relationship">
                <option value="work">仕事相手</option>
                <option value="boss">上司</option>
                <option value="client">取引先</option>
                <option value="customer">お客様</option>
                <option value="friend">友達</option>
                <option value="unknown">まだ関係が浅い相手</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label>雰囲気</label>
            <div class="segmented" data-group="tone">
              <button type="button" data-value="polite" class="active">丁寧</button>
              <button type="button" data-value="soft">やわらかめ</button>
              <button type="button" data-value="casual">自然</button>
            </div>
          </div>

          <div class="field">
            <label>長さ</label>
            <div class="segmented" data-group="length">
              <button type="button" data-value="short" class="active">短め</button>
              <button type="button" data-value="medium">標準</button>
              <button type="button" data-value="long">丁寧に</button>
            </div>
          </div>

          <div class="field">
            <label for="detail" id="detailLabel">入れたい内容</label>
            <textarea id="detail" placeholder="例：断りたい理由、希望日、次の対応、補足したいことなど"></textarea>
          </div>

          <div class="actions">
            <button class="button primary" id="generateBtn" type="button">文章を作る</button>
            <button class="button secondary" id="copyBtn" type="button">コピー</button>
            <button class="button secondary" id="clearBtn" type="button">クリア</button>
          </div>
        </section>

        <section class="panel">
          <h2>出力</h2>
          <div id="output" class="output"></div>
          <div class="template-grid">
            <button class="template-button" type="button" data-template-index="0">見本1</button>
            <button class="template-button" type="button" data-template-index="1">見本2</button>
            <button class="template-button" type="button" data-template-index="2">見本3</button>
          </div>
        </section>
      </div>

      <section class="seo-content">
        <h2>{tool.title}の使い方</h2>
        <p>
          {tool.title}は、毎回文章を考えるのが面倒な場面で使える無料ツールです。
          元の内容や相手から来た文章を入れて、目的や雰囲気を選ぶだけで、短く使いやすい文章に整えられます。
        </p>

        <div class="info-grid">
          <div>
            <h3>おすすめの使い方</h3>
            <ul>
              <li>相手に送る前の下書きとして使う</li>
              <li>出力された文章を、自分の言葉に少し直す</li>
              <li>相手との関係に合わせて丁寧さを調整する</li>
            </ul>
          </div>
          <div>
            <h3>注意点</h3>
            <ul>
              <li>個人情報や機密情報は入力しない</li>
              <li>重要な連絡は送信前に内容を確認する</li>
              <li>謝罪や契約に関わる文章は慎重に見直す</li>
            </ul>
          </div>
        </div>

        {
          relatedTools.length > 0 && (
            <div class="related-tools">
              {relatedTools.map((item) => (
                <a href={item.href}>{item.title}</a>
              ))}
            </div>
          )
        }
      </section>
    </div>
  </main>
  <div id="toast" class="toast"></div>
  <script type="application/json" id="tool-data" set:html={JSON.stringify(tool)}></script>
  <script is:inline src="/scripts/generic-writing-tool.js"></script>
</Layout>
