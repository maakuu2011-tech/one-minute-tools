---
import Layout from "../../components/Layout.astro";
import ToolCard from "../../components/ToolCard.astro";
import tools from "../../data/tools.json";

const featuredItems = [
  { id: "chat-reply", reason: "LINE・Slack・DMの返事を短く作る" },
  { id: "decline-reply", reason: "誘い・依頼・営業を角が立たない形で断る" },
  { id: "follow-up-message", reason: "返信がない相手に感じよく確認する" },
  { id: "soft-rewrite", reason: "きつく見える文章をやわらかく直す" },
  { id: "line-reply", reason: "友達や知人へのLINE返信を自然にする" },
  { id: "keigo-mail", reason: "仕事メールを自然な敬語に整える" },
]
  .map((item) => ({ ...item, tool: tools.find((tool) => tool.id === item.id) }))
  .filter((item) => item.tool);
const categories = ["すべて", ...Array.from(new Set(tools.map((tool) => tool.category)))];
---

<Layout title="ツール一覧｜無料で使える文章作成ツール集" description="チャット返信、敬語メール、断り方、催促文、謝罪文、言い換えなどを無料で作れる1分ツールの一覧です。用途やカテゴリから探せます。">
  <main class="page">
    <div class="container">
      <div class="section__head tools-head">
        <div>
          <h1>ツール一覧</h1>
          <p class="section__note">検索するか、カテゴリから選んでください。よく使うものは上にまとめています。</p>
          <p class="section__note">何を使えばいいかわからないときは、<a class="text-link" href="/use/">用途から探す</a>のがおすすめです。</p>
        </div>
        <div class="mini-mascot" aria-label="1分ツールの案内役">
          <img src="/images/mascot-girl.png" alt="1分ツールのマスコットキャラクター" />
          <span>迷ったら検索してね。</span>
        </div>
      </div>

      <section class="finder-panel" aria-label="ツール検索">
        <div class="field finder-search">
          <label for="toolSearch">ツール名・用途で探す</label>
          <input id="toolSearch" type="search" placeholder="例：LINE、断り方、催促、敬語、言い換え" />
        </div>

        <div class="category-filter" aria-label="カテゴリで絞り込み">
          {categories.map((category) => (
            <button type="button" class="category-pill" data-category={category} aria-pressed={category === "すべて" ? "true" : "false"}>
              {category}
            </button>
          ))}
        </div>
      </section>

      <section class="section tools-section">
        <div class="section__head compact-head">
          <div>
            <h2>人気ツール</h2>
            <p class="section__note">使われる場面が多い入口を、順位つきでまとめています。</p>
          </div>
        </div>
        <div class="popular-tool-list popular-tool-list--wide">
          {featuredItems.map((item, index) => (
            <a class="popular-tool" href={item.tool.href}>
              <span class="popular-tool__rank">{index + 1}</span>
              <div>
                <span class="tool-card__category">{item.tool.category}</span>
                <h3>{item.tool.title}</h3>
                <p>{item.reason}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="section tools-section">
        <div class="section__head compact-head">
          <div>
            <h2>すべてのツール</h2>
            <p class="section__note"><span id="toolCount">{tools.length}</span>件表示中</p>
          </div>
        </div>
        <div class="tool-grid tool-grid--compact" id="toolList">
          {tools.map((tool) => (
            <div
              class="tool-item"
              data-title={tool.title}
              data-description={tool.description}
              data-category={tool.category}
              data-keywords={(tool.keywords || []).join(" ")}
            >
              <ToolCard tool={tool} />
            </div>
          ))}
        </div>
        <div class="empty-state" id="emptyState" hidden>
          <img src="/images/mascot-girl.png" alt="1分ツールのマスコットキャラクター" />
          <div>
            <strong>見つかりませんでした</strong>
            <p>別の言葉で検索するか、欲しいツールを要望として送ってください。</p>
            <a class="button secondary" href="/contact/">欲しいツールを送る</a>
          </div>
        </div>
      </section>
      </div>
  </main>
  <script is:inline src="/scripts/tool-finder.js"></script>
</Layout>
