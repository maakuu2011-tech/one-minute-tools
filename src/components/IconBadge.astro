---
const { name = "tool", label = "" } = Astro.props;

const icons = {
  tool: ["M5 12h14", "M12 5v14", "M7 7h10v10H7z"],
  chat: ["M5 6h14v9H9l-4 4V6z", "M8 10h8", "M8 13h5"],
  mail: ["M4 7h16v10H4z", "M4 8l8 6 8-6"],
  decline: ["M7 7l10 10", "M17 7L7 17", "M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z"],
  remind: ["M12 7v5l3 2", "M12 21a8 8 0 1 0 0-16 8 8 0 0 0 0 16z", "M7 3L4 6", "M17 3l3 3"],
  rewrite: ["M5 19h14", "M7 15l8-8 3 3-8 8H7z"],
  example: ["M7 5h10", "M7 9h10", "M7 13h6", "M5 3h14v18H5z"],
  game: ["M8 14h.01", "M16 14h.01", "M10 11h4", "M12 9v4", "M6 17l2-8h8l2 8"],
  minute: ["M12 7v5l4 2", "M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z"],
  search: ["M11 18a7 7 0 1 0 0-14 7 7 0 0 0 0 14z", "M16 16l4 4"],
  rank: ["M6 19V9", "M12 19V5", "M18 19v-7", "M4 19h16"],
};

const paths = icons[name] || icons.tool;
---

<span class="icon-badge" aria-label={label || undefined} aria-hidden={label ? "false" : "true"}>
  <svg viewBox="0 0 24 24" role="img">
    {paths.map((path) => <path d={path}></path>)}
  </svg>
</span>
