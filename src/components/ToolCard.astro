---
import IconBadge from "./IconBadge.astro";

const { tool } = Astro.props;
const isSoon = tool.status !== "公開中";

const categoryIcons = {
  チャット: "chat",
  メール: "mail",
  断り方: "decline",
  催促: "remind",
  言い換え: "rewrite",
  謝罪: "decline",
  お礼: "mail",
  日程調整: "minute",
  依頼: "tool",
  連絡: "chat",
  返信: "chat",
  報告: "rank",
};

const iconName = categoryIcons[tool.category] || "tool";
---

<a class="tool-card" href={tool.href}>
  <div class="tool-card__top">
    <IconBadge name={iconName} />
    <span class="tool-card__category">{tool.category}</span>
  </div>
  <h3>{tool.title}</h3>
  <p>{tool.description}</p>
  <span class:list={["tool-card__status", { "is-soon": isSoon }]}>{tool.status}</span>
</a>
