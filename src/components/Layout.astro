---
import "../styles/global.css";

const {
  title = "1分ツール",
  description = "仕事の返信、メール、断り文、催促文などを1分で作れる無料の文章作成ツール集です。",
  structuredData = [],
} = Astro.props;

const siteUrl = "https://one-minute-tools.pages.dev";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const organizationStructuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "1分ツール",
  url: siteUrl,
  logo: new URL("/images/mascot-girl.png", siteUrl).toString(),
};

const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "1分ツール",
  alternateName: ["一分ツール", "one minute tools", "one-minute-tools"],
  url: siteUrl,
  description: "仕事のチャット返信、敬語メール、断り文、催促文、謝罪文を1分で作れる無料の文章作成ツール集です。",
  publisher: {
    "@type": "Organization",
    name: "1分ツール",
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteUrl}/tools/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};

const structuredDataItems = [organizationStructuredData, websiteStructuredData, ...structuredData];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="zrtqkf9p1opOex4uGNK9XnGE6TKCz4spJKwI522OYLg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="1分ツール" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/images/mascot-girl.png" />
    <link rel="apple-touch-icon" href="/images/mascot-girl.png" />
    <link rel="alternate" type="application/rss+xml" title="1分ツール 更新情報" href="/rss.xml" />
    {structuredDataItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)}></script>)}
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">
          <span class="brand__mark">1</span>
          <span>
            <span class="brand__name">1分ツール</span>
            <span class="brand__note">仕事の文章を1分で整える</span>
          </span>
        </a>
        <nav class="nav" aria-label="メインナビゲーション">
          <a href="/tools/">文章ツール</a>
          <a href="/use/">場面別の例文</a>
          <a class="nav__optional" href="/one-minute/">1分コンテンツ</a>
          <a class="nav__secondary" href="/games/">ゲーム</a>
          <a class="nav__optional" href="/updates/">更新</a>
          <a class="nav__optional" href="/about/">このサイト</a>
          <a class="nav__optional" href="/privacy/">プライバシー</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="container">
        <div>© 1分ツール</div>
        <div class="footer-links">
          <a href="/about/">このサイトについて</a>
          <a href="/updates/">更新履歴</a>
          <a href="/rss.xml">RSS</a>
          <a href="/privacy/">プライバシーポリシー</a>
          <a href="/contact/">お問い合わせ</a>
        </div>
      </div>
    </footer>
  </body>
</html>
