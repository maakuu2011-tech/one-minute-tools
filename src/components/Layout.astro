---
import "../styles/global.css";

const {
  title = "1分ツール",
  description = "仕事や生活のちょっと困ったをすぐ片づける小ツール集です。",
  structuredData = [],
} = Astro.props;

const siteUrl = "https://one-minute-tools.pages.dev";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "1分ツール",
  url: siteUrl,
  description: "チャット返信、断り方、催促文、言い換えなどをすぐ作れる無料ツール集です。",
};

const structuredDataItems = [websiteStructuredData, ...structuredData];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="zrtqkf9p1opOex4uGNK9XnGE6TKCz4spJKwI522OYLg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="1分ツール" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/images/mascot-girl.png" />
    <link rel="apple-touch-icon" href="/images/mascot-girl.png" />
    {structuredDataItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)}></script>)}
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">
          <span class="brand__mark">1</span>
          <span>
            <span class="brand__name">1分ツール</span>
            <span class="brand__note">案内役つきの小さな道具箱</span>
          </span>
        </a>
        <nav class="nav" aria-label="メインナビゲーション">
          <a href="/tools/">ツール一覧</a>
          <a href="/use/">用途から探す</a>
          <a href="/one-minute/">1分コンテンツ</a>
          <a href="/about/">このサイトについて</a>
          <a href="/privacy/">プライバシー</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="container">
        <div>© 1分ツール</div>
        <div class="footer-links">
          <a href="/about/">このサイトについて</a>
          <a href="/privacy/">プライバシーポリシー</a>
          <a href="/contact/">お問い合わせ</a>
        </div>
      </div>
    </footer>
  </body>
</html>
